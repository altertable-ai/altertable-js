{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "plugins": [
    {
      "type": "node-workspace",
      "merge": false
    },
    {
      "type": "linked-versions",
      "groupName": "altertable-sdk",
      "components": [
        "altertable-js",
        "altertable-react"
      ]
    }
  ],
  "packages": {
    "packages/altertable-js": {
      "release-type": "node",
      "package-name": "@altertable/altertable-js",
      "component": "altertable-js"
    },
    "packages/altertable-react": {
      "release-type": "node",
      "package-name": "@altertable/altertable-react",
      "component": "altertable-react"
    }
  }
}
